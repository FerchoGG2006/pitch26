generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  xp            Int           @default(0)
  level         Int           @default(1)
  coins         Int           @default(0)
  gems          Int           @default(0)
  hasSeason     Boolean       @default(false)
  seasonExpiry  DateTime?
  nation        String?
  accounts      Account[]
  packs         PackOpening[]
  sessions      Session[]
  collection    UserCard[]
}

model Player {
  id          String       @id @default(cuid())
  externalId  String       @unique
  name        String
  nationality String
  flag        String
  position    Position
  teamName    String?
  updatedAt   DateTime     @updatedAt
  cards       PlayerCard[]
}

model PlayerCard {
  id              String     @id @default(cuid())
  playerId        String
  tier            CardTier   @default(BASE)
  rating          Int
  ritmo           Int        @default(70)
  tiro            Int        @default(70)
  vision          Int        @default(70)
  dribling        Int        @default(70)
  pase            Int        @default(70)
  fisico          Int        @default(70)
  deltaToday      Int        @default(0)
  deltaTournament Int        @default(0)
  lastEvent       String?
  isMomento       Boolean    @default(false)
  momentoExpiry   DateTime?
  momentoMatch    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  player          Player     @relation(fields: [playerId], references: [id])
  userCards       UserCard[]
}

model UserCard {
  id            String       @id @default(cuid())
  userId        String
  cardId        String
  obtainedAt    DateTime     @default(now())
  isFavorite    Boolean      @default(false)
  packOpeningId String?
  card          PlayerCard   @relation(fields: [cardId], references: [id])
  packOpening   PackOpening? @relation(fields: [packOpeningId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model PackOpening {
  id       String     @id @default(cuid())
  userId   String
  packType PackType
  openedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards    UserCard[]
}

enum CardTier {
  BASE
  RISING
  ELITE
  LEGEND
  MOMENTO
}

enum Position {
  GK
  DEF
  MID
  FWD
}

enum PackType {
  WELCOME
  STANDARD
  PREMIUM
  MOMENTO
}
